# Copy this file to .env and adjust values for your local environment.
# .env is git-ignored; .env.example is the committed reference.

# Host port that the test Postgres container is exposed on.
# Change this if port 5432 conflicts with another Postgres instance on your machine.
POSTGRES_PORT=15432

# Full connection URL used by the integration tests.
# Must match the POSTGRES_PORT above.
DATABASE_URL=postgres://postgres:postgres@localhost:15432/epoch_pg_test
